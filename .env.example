# ─────────────────────────────────────────────────────────────────
# Heavenly Dreams CRM — Variables de entorno
# Copia este archivo como .env y llena los valores reales
# ─────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────
NODE_ENV=production          # development | production
PORT=3000                    # Puerto del servidor Express
HOST_PORT=80                 # Puerto expuesto en Docker (mapea a PORT)

# ── Base de datos (PostgreSQL) ────────────────────────────────────
# Formato: postgres://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgres://hdreams_user:CAMBIA_ESTA_PASSWORD@localhost:5432/hdreams_crm

# Variables usadas por docker-compose (si no usas DATABASE_URL directa)
POSTGRES_DB=hdreams_crm
POSTGRES_USER=hdreams_user
POSTGRES_PASSWORD=CAMBIA_ESTA_PASSWORD   # ⚠️ Cambia esto en producción

# ── Google Gemini AI (proveedor principal) ────────────────────────
# Obtén claves en: https://aistudio.google.com/app/apikey
# El servidor rota automáticamente si una clave agota su cuota (429).
GEMINI_API_KEY=AIzaSy_TU_PRIMERA_CLAVE
GEMINI_API_KEY_2=AIzaSy_TU_SEGUNDA_CLAVE   # Opcional — fallback Gemini

# ── OpenAI / ChatGPT (fallback final) ────────────────────────────
# Se usa SOLO si ambas claves Gemini fallan por cuota.
# Obtén tu clave en: https://platform.openai.com/api-keys
# Formato: sk-proj-...
OPENAI_API_KEY=sk-proj-TU_CLAVE_OPENAI     # Opcional

# ── Seguridad ─────────────────────────────────────────────────────
# Salt para el hashing de contraseñas — cámbialo en producción y NO lo compartas
PASSWORD_SALT=cambia_este_salt_en_produccion_2026

# ── Twilio (SMS, WhatsApp y llamadas de voz) ─────────────────────
# Obtén tus credenciales en: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Número Twilio de origen (formato E.164: +1XXXXXXXXXX)
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# Número WhatsApp de origen (usa el Sandbox Twilio en desarrollo)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── (Opcional) URL pública de la app ─────────────────────────────
# Necesaria para links absolutos, OAuth callbacks, etc.
APP_URL=https://tu-dominio.com

# ── Plan A (Foundation) — Telefonía en la Nube · Agente 2 (Validación) ─────
# Vapi.ai maneja el agente IA conversacional. Twilio actua como SIP trunk /
# numero PSTN para llamadas entrantes y salientes. Llenar despues.
#
# 1) Twilio: usa el Phone Number SID del numero comprado para llamadas de voz.
#    Si solo tienes el numero E.164, dejalo en TWILIO_PHONE_NUMBER y
#    TWILIO_FROM_NUMBER puede quedarse para SMS/WhatsApp.
TWILIO_PHONE_NUMBER=+52XXXXXXXXXX
#
# 2) Vapi.ai: claves en https://dashboard.vapi.ai/account
#    - Private Key: para llamadas API server-to-server.
#    - Public Key: opcional (web SDK).
#    - Assistant ID: el ID del Asistente "Validacion HD" creado en Vapi.
#    - Phone Number ID: ID del numero Twilio importado a Vapi.
#    - Webhook Secret: HMAC para validar webhooks de Vapi.
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=
#
# 3) URL publica del backend para que Twilio/Vapi alcancen los webhooks.
#    En desarrollo usa ngrok / cloudflared. En produccion: dominio HTTPS.
#    Ej: https://crm.heavenlydreams.mx
PUBLIC_BASE_URL=
